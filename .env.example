# ─── App ──────────────────────────────────────────
NEXTAUTH_URL=https://your-siteforge-app.vercel.app
NEXTAUTH_SECRET=CHANGE_ME_use_openssl_rand_base64_32

# ─── MongoDB Atlas ─────────────────────────────────
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/siteforge?retryWrites=true&w=majority

# ─── Cloudinary ────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=your_cloudinary_secret
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name

# ─── OpenAI ────────────────────────────────────────
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxx

# ─── Vercel Deployment ─────────────────────────────
VERCEL_API_TOKEN=your_vercel_personal_access_token
VERCEL_TEAM_ID=team_xxxxxxxxxxxxxxxx

# ─── Admin Seed ────────────────────────────────────
ADMIN_EMAIL=gladwin@mitsumi.ae
ADMIN_INITIAL_PASSWORD=Change_Me_On_First_Login!
